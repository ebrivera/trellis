{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "strict": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@trellis/ui/*": ["apps/web/src/components/ui/*"],
      "@trellis/utils/*": ["packages/utils/src/*"],
      "@trellis/types/*": ["packages/types/src/*"]
    }
  },
  "exclude": ["node_modules", "**/node_modules", "**/.next", "**/dist"]
}
